# Copy this file to .env and fill in your own values.
# .env is git-ignored, so your real key never gets committed.
#
# Pick ONE LLM backend below. The agent auto-detects whichever key is set.
# With none set, `agent.py` falls back to the offline --simulate walkthrough.

# --- Option A: Groq (recommended) ---------------------------------------------
# Free API key, no credit card. Get one at https://console.groq.com/keys
# GROQ_API_KEY=gsk_your-free-groq-key-here
# GROQ_MODEL=llama-3.3-70b-versatile

# --- Option B: Google Gemini (free tier) ---------------------------------------
# GEMINI_API_KEY=your-gemini-key-here
# GEMINI_MODEL=gemini-2.0-flash

# --- Option C: Ollama (fully local, no key at all) ----------------------------
# LLM_PROVIDER=ollama
# OLLAMA_MODEL=llama3.1
# OLLAMA_BASE_URL=http://localhost:11434/v1

# --- Option D: Anthropic (Claude) ---------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_MODEL=claude-sonnet-4-5

# --- Option E: OpenAI or any OpenAI-compatible endpoint ------------------------
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# --- LLM fallback chain (comma-separated providers) ---------------------------
# LLM_FALLBACK_CHAIN=groq,openai,anthropic

# --- Mock / real backend URLs -------------------------------------------------
PROMETHEUS_URL=http://localhost:9091
ELK_URL=http://localhost:9093
ANSIBLE_URL=http://localhost:9092

# mock (default laptop mocks) | real (PromQL / ES DSL / AWX)
# AUTOSRE_BACKEND_MODE=mock

# Outbound auth for real Prometheus / Elasticsearch / AWX
# AUTOSRE_HTTP_AUTHORIZATION=Bearer your-token
# AUTOSRE_HTTP_HEADERS_JSON={"X-Scope-OrgID":"ops"}

# Real Prometheus PromQL template ({metric} and {service} substituted)
# PROMETHEUS_QUERY_TEMPLATE={metric}{{service="{service}"}}

# Elasticsearch index / data stream for log search
# ELK_INDEX=logs-*

# Map playbook filenames to AWX job template IDs
# AWX_JOB_TEMPLATE_MAP_JSON={"restore_db_pool.yml":"12","clean_disk_space.yml":"13"}

# --- Production hardening -----------------------------------------------------
# AUTOSRE_TIMEOUT=300
# AUTOSRE_MAX_ITERATIONS=12

# Approval gate: auto | prompt | webhook
# AUTOSRE_APPROVAL_MODE=auto
# AUTOSRE_APPROVAL_WEBHOOK_URL=http://localhost:9000/approve

# Independent rollback playbook if metrics remain above healthy_thresholds
# AUTOSRE_ROLLBACK_PLAYBOOK=restart_service.yml

# AUTOSRE_DB_PATH=autosre.db
# AUTOSRE_PORT=8080

# Require Authorization: Bearer <token> on POST /webhook/alertmanager
# AUTOSRE_WEBHOOK_TOKEN=change-me

# --- Optional: Dify path (trigger_fault.py) -----------------------------------
# DIFY_API_BASE=http://localhost/v1
# DIFY_WORKFLOW_API_KEY=app-your-workflow-api-key-here
